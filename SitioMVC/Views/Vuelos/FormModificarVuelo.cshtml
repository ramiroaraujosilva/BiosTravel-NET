@model Entidades_Compartidas.Vuelos

@{
    ViewBag.Title = "Modificar Vuelo";
    Layout = "~/Views/Shared/_LayoutPage2.cshtml";
}

<h2>Modificar Vuelo</h2>
@ViewBag.Mensaje

@Html.ActionLink("Volver al Listado de Vuelos", "FormListarVuelos")


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>Vuelos</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="form-group">
            @Html.LabelFor(model => model.Codigo, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DisplayFor(model => model.Codigo, new { htmlAttributes = new { @class = "form-control" } })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.FechaHoraP, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.FechaHoraP, new { htmlAttributes = new { @type = "datetime-local" } })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.FechaHoraL, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.FechaHoraL, new { htmlAttributes = new { @type = "datetime-local" } })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.PrecioV, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.PrecioV, new { htmlAttributes = new { @class = "form-control" } })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Estado de Partida", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("CodigoPartida", (SelectList)ViewBag.ListaEstadosPartida)
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Estado de Arribo", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("CodigoArribo", (SelectList)ViewBag.ListaEstadosArribo)
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Modificar" class="btn btn-default" />
            </div>
        </div>
    </div>
}
