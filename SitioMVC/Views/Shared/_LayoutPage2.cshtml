<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Bios Travel</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <script src="~/Scripts/modernizr-2.8.3.js"></script>
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                @Html.ActionLink("Alta de Paquetes Viajes", "FormAltaPaqueteViaje", "PaquetesViajes", new { area = "" }, new { @class = "navbar-brand" })
                @Html.ActionLink("Listado de Paquetes Viajes", "FormListarPaquetesViajes", "PaquetesViajes", new { area = "" }, new { @class = "navbar-brand" })
                @Html.ActionLink("Empleados", "MantenimientoEmpleados", "Empleados", new { area = "" }, new { @class = "navbar-brand" })
                @Html.ActionLink("Estados", "FormListarEstados", "Estados", new { area = "" }, new { @class = "navbar-brand" })
                @Html.ActionLink("Vuelos", "FormListarVuelos", "Vuelos", new { area = "" }, new { @class = "navbar-brand" })
                @Html.ActionLink("Hospedajes", "FormListarCRUDHospedajes", "Hospedajes", new { area = "" }, new { @class = "navbar-brand" })
                @Html.ActionLink("Listado de Hospedajes", "FormListarHospedajes", "Hospedajes", new { area = "" }, new { @class = "navbar-brand" })
                @Html.ActionLink("Cerrar sesión", "Deslogueo", "Empleados", new { area = "" }, new { @class = "navbar-brand" })
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav">
                </ul>
            </div>
        </div>
    </div>
    <div>
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Bios Travel</p>
        </footer>
    </div>
</body>
</html>
